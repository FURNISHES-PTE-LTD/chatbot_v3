# Copy to .env.local and fill in your keys

# LLM Provider (pick one)
OPENAI_API_KEY=sk-...
# OR
# ANTHROPIC_API_KEY=sk-ant-...

# Database (SQLite for dev; use Postgres URL for prod)
DATABASE_URL=file:./dev.db

# App
NEXT_PUBLIC_APP_NAME=Eva

# NextAuth (required in production; set these for session/JWT)
NEXTAUTH_SECRET=your-secret-at-least-32-chars-long-for-jwt
NEXTAUTH_URL=http://localhost:3000

# Optional: Google OAuth (enable Google sign-in when both are set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
