# Copy to .env.local and fill in your keys

# LLM Provider (pick one)
OPENAI_API_KEY=sk-...
# OR
# ANTHROPIC_API_KEY=sk-ant-...

# Database (PostgreSQL; docker compose up -d for local)
DATABASE_URL=postgresql://eva:eva_local@localhost:5432/eva_dev

# App
NEXT_PUBLIC_APP_NAME=Eva

# NextAuth (required in production; set these for session/JWT)
NEXTAUTH_SECRET=your-secret-at-least-32-chars-long-for-jwt
NEXTAUTH_URL=http://localhost:3000

# Optional: Google OAuth (enable Google sign-in when both are set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Sentry (error tracking; only enabled when NEXT_PUBLIC_SENTRY_DSN is set)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
