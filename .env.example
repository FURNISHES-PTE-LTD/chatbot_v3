# Copy to .env.local and fill in your keys
# cp .env.example .env.local

# LLM Provider (required for chat and extraction)
OPENAI_API_KEY=sk-...

# Database
# PostgreSQL (default; use docker compose up -d for local):
#   DATABASE_URL=postgresql://eva:eva_local@localhost:5432/eva_dev
# SQLite (local testing, no Docker):
#   DATABASE_URL=file:./prisma/dev.db
#   Then run: npm run db:generate:sqlite && npm run db:push:sqlite
DATABASE_URL=postgresql://eva:eva_local@localhost:5432/eva_dev

# App
NEXT_PUBLIC_APP_NAME=Eva

# NextAuth (set these to avoid "NO_SECRET" / "JWT_SESSION_ERROR" in dev)
NEXTAUTH_SECRET=your-secret-at-least-32-chars-long-for-jwt
NEXTAUTH_URL=http://localhost:3000

# Optional: Google OAuth (enable Google sign-in when both are set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Sentry (error tracking; only enabled when NEXT_PUBLIC_SENTRY_DSN is set)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
